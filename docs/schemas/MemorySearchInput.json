{
  "additionalProperties": false,
  "properties": {
    "include_history": {
      "default": false,
      "title": "Include History",
      "type": "boolean"
    },
    "limit": {
      "default": 10,
      "maximum": 50,
      "minimum": 1,
      "title": "Limit",
      "type": "integer"
    },
    "query": {
      "maxLength": 2048,
      "minLength": 1,
      "title": "Query",
      "type": "string"
    },
    "recency_lambda": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Recency Lambda"
    },
    "since": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Since"
    },
    "tags": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tags"
    },
    "type": {
      "anyOf": [
        {
          "enum": [
            "note",
            "decision",
            "fact",
            "snippet",
            "question"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Type"
    },
    "until": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Until"
    }
  },
  "required": [
    "query"
  ],
  "title": "MemorySearchInput",
  "type": "object"
}
