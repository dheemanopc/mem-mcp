[Unit]
Description=mem-mcp DCR client cleanup (T-4.9)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=memmcp
Group=memmcp
WorkingDirectory=/opt/mem-mcp
EnvironmentFile=/etc/mem-mcp/env
ExecStart=/home/memmcp/.local/bin/poetry run python -m mem_mcp.jobs cleanup_clients

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
LimitNOFILE=4096
