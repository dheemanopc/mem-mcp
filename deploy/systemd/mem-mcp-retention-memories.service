[Unit]
Description=mem-mcp soft/hard-delete memories per retention policy (T-7.14)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=memmcp
Group=memmcp
WorkingDirectory=/opt/mem-mcp
EnvironmentFile=/etc/mem-mcp/env
ExecStart=/home/memmcp/.local/bin/poetry run python -m mem_mcp.jobs retention_memories

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
LimitNOFILE=4096
