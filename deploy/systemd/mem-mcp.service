[Unit]
Description=mem-mcp FastAPI service
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=exec
User=memmcp
Group=memmcp
WorkingDirectory=/opt/mem-mcp
EnvironmentFile=/etc/mem-mcp/env
ExecStart=/home/memmcp/.local/bin/poetry run uvicorn mem_mcp.main:app \
    --host 127.0.0.1 --port 8080 \
    --proxy-headers --forwarded-allow-ips '127.0.0.1' \
    --workers 2
Restart=on-failure
RestartSec=5
TimeoutStopSec=15

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/mem-mcp /var/lib/mem-mcp
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
