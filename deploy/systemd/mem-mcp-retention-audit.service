[Unit]
Description=mem-mcp anonymize + hard-delete audit log (T-7.15)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=memmcp
Group=memmcp
WorkingDirectory=/opt/mem-mcp
EnvironmentFile=/etc/mem-mcp/env
ExecStart=/home/memmcp/.local/bin/poetry run python -m mem_mcp.jobs retention_audit

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
LimitNOFILE=4096
