[Unit]
Description=mem-mcp nightly DB backup to S3 (T-9.7)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=memmcp
Group=memmcp
WorkingDirectory=/opt/mem-mcp
EnvironmentFile=/etc/mem-mcp/env
ExecStart=/opt/mem-mcp/deploy/scripts/pg_dump_to_s3.sh

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
LimitNOFILE=4096
